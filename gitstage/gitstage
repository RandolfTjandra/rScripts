#!/bin/zsh

fzf --version >/dev/null 2>&1 || {
  echo "fzf is not installed. Please install it first." >&2
  exit 1
}

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "gitstage must be run inside a Git repository." >&2
  exit 1
}

show_diff() {
  local file_path="$1"

  case "$file_path" in
    "__action_tracked__"|"__action_untracked__")
      echo "Move the cursor to a file to view its diff."
      return
      ;;
  esac

  command -v diff-so-fancy >/dev/null 2>&1 || {
    echo "diff-so-fancy is not installed. Install it to view file diffs." >&2
    return 1
  }

  if git ls-files --error-unmatch -- "$file_path" >/dev/null 2>&1; then
    git diff --no-ext-diff -- "$file_path" | diff-so-fancy
  else
    git diff --no-index -- /dev/null "$file_path" 2>/dev/null | diff-so-fancy
  fi
}

if [[ "$1" == "--show-diff" ]]; then
  show_diff "$2"
  exit $?
fi

[[ -t 0 && -t 1 ]] || {
  echo "gitstage requires an interactive terminal." >&2
  exit 1
}

tracked_files=()
while IFS= read -r file_path; do
  [[ -n "$file_path" ]] && tracked_files+=("$file_path")
done <<EOF
$(git diff --name-only)
EOF

untracked_files=()
while IFS= read -r file_path; do
  [[ -n "$file_path" ]] && untracked_files+=("$file_path")
done <<EOF
$(git ls-files --others --exclude-standard)
EOF

if [[ ${#tracked_files[@]} -eq 0 && ${#untracked_files[@]} -eq 0 ]]; then
  echo "No unstaged or untracked files to stage." >&2
  exit 0
fi

ACTION_TRACKED="[Tracked only]"
ACTION_UNTRACKED="[Untracked only]"

status_label_for_path() {
  local file_path="$1"
  local status_line

  status_line=$(git status --short -- "$file_path" | sed -n '1p')
  [[ -n "$status_line" ]] && printf '%s\n' "$status_line" || printf '%s\n' "$file_path"
}

colorize_status_label() {
  local label="$1"
  local xy="${label:0:2}"
  local rest="${label:2}"
  local color=""

  case "$xy" in
    " M"|"M ") color="\033[32m" ;;
    "MM") color="\033[33m" ;;
    " D"|"D "|"DD") color="\033[31m" ;;
    "A "|"AM"|"AD") color="\033[32m" ;;
    "R "|" R"|"RM") color="\033[36m" ;;
    "C "|" C") color="\033[36m" ;;
    "U "|" U"|"UU"|"AA") color="\033[35m" ;;
  esac

  if [[ -n "$color" ]]; then
    printf "${color}%s\033[0m%s" "$xy" "$rest"
  else
    printf '%s' "$label"
  fi
}

choices=(
  "$ACTION_TRACKED"$'\t'"__action_tracked__"
  "$ACTION_UNTRACKED"$'\t'"__action_untracked__"
)

for file_path in "${tracked_files[@]}"; do
  status_label=$(status_label_for_path "$file_path")
  display_label=$(colorize_status_label "$status_label")
  choices+=("$display_label"$'\t'"$file_path")
done

for file_path in "${untracked_files[@]}"; do
  status_label=$(status_label_for_path "$file_path")
  display_label=$(colorize_status_label "$status_label")
  choices+=("$display_label"$'\t'"$file_path")
done

selected=$(
  printf '%s\n' "${choices[@]}" |
    fzf \
      --multi \
      --ansi \
      --layout=reverse \
      --delimiter=$'\t' \
      --with-nth=1 \
      --preview="${(q)0} --show-diff {2}" \
      --preview-window="right,60%,border-left" \
      --bind="space:toggle+down,ctrl-a:select-all,tab:toggle-preview" \
      --header="Select files to stage. Space toggles and moves down. Tab toggles diff. Enter confirms."
)

if [[ -z "$selected" ]]; then
  echo "No files selected. Aborting." >&2
  exit 0
fi

selected_paths=()
selected_tracked=false
selected_untracked=false

while IFS= read -r item; do
  [[ -z "$item" ]] && continue
  item="${item#*$'\t'}"
  case "$item" in
    "__action_tracked__")
      selected_tracked=true
      ;;
    "__action_untracked__")
      selected_untracked=true
      ;;
    *)
      selected_paths+=("$item")
      ;;
  esac
done <<EOF
$selected
EOF

[[ "$selected_tracked" == true ]] && selected_paths+=("${tracked_files[@]}")
[[ "$selected_untracked" == true ]] && selected_paths+=("${untracked_files[@]}")

deduped_paths=()
for candidate in "${selected_paths[@]}"; do
  [[ -z "$candidate" ]] && continue

  already_added=false
  for existing in "${deduped_paths[@]}"; do
    if [[ "$existing" == "$candidate" ]]; then
      already_added=true
      break
    fi
  done

  [[ "$already_added" == false ]] && deduped_paths+=("$candidate")
done

if [[ ${#deduped_paths[@]} -eq 0 ]]; then
  echo "No files selected. Aborting." >&2
  exit 0
fi

git add -- "${deduped_paths[@]}" || exit 1

printf "Staged %d file(s):\n" "${#deduped_paths[@]}"
printf '  %s\n' "${deduped_paths[@]}"
