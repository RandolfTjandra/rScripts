#!/bin/zsh

[[ -t 0 && -t 1 ]] || {
  echo "gitstage requires an interactive terminal." >&2
  exit 1
}

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "gitstage must be run inside a Git repository." >&2
  exit 1
}

tracked_files=()
while IFS= read -r file_path; do
  [[ -n "$file_path" ]] && tracked_files+=("$file_path")
done <<EOF
$(git diff --name-only)
EOF

untracked_files=()
while IFS= read -r file_path; do
  [[ -n "$file_path" ]] && untracked_files+=("$file_path")
done <<EOF
$(git ls-files --others --exclude-standard)
EOF

if [[ ${#tracked_files[@]} -eq 0 && ${#untracked_files[@]} -eq 0 ]]; then
  echo "No unstaged or untracked files to stage." >&2
  exit 0
fi

ACTION_TRACKED="[Tracked only]"
ACTION_UNTRACKED="[Untracked only]"
MAX_VISIBLE_CHOICES=20

status_label_for_path() {
  local file_path="$1"
  local status_line

  status_line=$(git status --short -- "$file_path" | sed -n '1p')
  [[ -n "$status_line" ]] && printf '%s\n' "$status_line" || printf '%s\n' "$file_path"
}

colorize_status_label() {
  local label="$1"
  local xy="${label:0:2}"
  local rest="${label:2}"
  local color=""

  case "$xy" in
    " M"|"M ") color="\033[32m" ;;
    "MM") color="\033[33m" ;;
    " D"|"D "|"DD") color="\033[31m" ;;
    "A "|"AM"|"AD") color="\033[32m" ;;
    "R "|" R"|"RM") color="\033[36m" ;;
    "C "|" C") color="\033[36m" ;;
    "U "|" U"|"UU"|"AA") color="\033[35m" ;;
  esac

  if [[ -n "$color" ]]; then
    printf "${color}%s\033[0m%s" "$xy" "$rest"
  else
    printf '%s' "$label"
  fi
}

count_selected_choices() {
  local selected_count=0
  local index

  for ((index = 1; index <= ${#selected_flags[@]}; index++)); do
    [[ "${selected_flags[index]}" == "1" ]] && ((selected_count++))
  done

  printf '%d\n' "$selected_count"
}

update_scroll_offset() {
  if (( cursor_index < scroll_offset )); then
    scroll_offset=$cursor_index
  elif (( cursor_index >= scroll_offset + MAX_VISIBLE_CHOICES )); then
    scroll_offset=$((cursor_index - MAX_VISIBLE_CHOICES + 1))
  fi
}

move_cursor_up() {
  if (( cursor_index > 1 )); then
    ((cursor_index--))
    update_scroll_offset
  fi
}

move_cursor_down() {
  if (( cursor_index < ${#choice_labels[@]} )); then
    ((cursor_index++))
    update_scroll_offset
  fi
}

toggle_current_choice() {
  if [[ "${selected_flags[cursor_index]}" == "1" ]]; then
    selected_flags[cursor_index]=0
  else
    selected_flags[cursor_index]=1
  fi
}

select_all_choices() {
  local index

  for ((index = 1; index <= ${#selected_flags[@]}; index++)); do
    selected_flags[index]=1
  done
}

render_selector() {
  local total_choices=${#choice_labels[@]}
  local window_end=$((scroll_offset + MAX_VISIBLE_CHOICES - 1))
  local index
  local cursor_marker
  local selection_marker

  (( window_end > total_choices )) && window_end=$total_choices

  printf '\033[H\033[2J'
  printf 'Select files to stage. Space toggles and moves down. Enter confirms.\n'
  printf 'Use arrow keys or j/k to move. Ctrl+A selects all. q cancels.\n\n'

  for ((index = scroll_offset; index <= window_end; index++)); do
    cursor_marker="  "
    selection_marker="[ ]"

    (( index == cursor_index )) && cursor_marker="> "
    [[ "${selected_flags[index]}" == "1" ]] && selection_marker="[x]"

    printf '%s%s %s\n' "$cursor_marker" "$selection_marker" "${display_labels[index]}"
  done

  if (( total_choices > MAX_VISIBLE_CHOICES )); then
    printf '\nShowing %d-%d of %d\n' "$scroll_offset" "$window_end" "$total_choices"
  else
    printf '\n%d item(s)\n' "$total_choices"
  fi

  printf '%s selected\n' "$(count_selected_choices)"
}

cleanup_selector() {
  [[ -n "$original_stty_state" ]] && stty "$original_stty_state" >/dev/null 2>&1

  if [[ "$selector_active" == true ]]; then
    printf '\033[?25h\033[?1049l'
    selector_active=false
  fi
}

run_selector() {
  local key
  local next_key
  local arrow_key

  original_stty_state=$(stty -g)
  selector_active=true

  printf '\033[?1049h\033[?25l'
  stty -echo -icanon min 1 time 0

  while true; do
    render_selector

    IFS= read -rsk1 key || return 1

    case "$key" in
      $'\n'|$'\r')
        return 0
        ;;
      ' ')
        toggle_current_choice
        move_cursor_down
        ;;
      'j')
        move_cursor_down
        ;;
      'k')
        move_cursor_up
        ;;
      'q')
        return 1
        ;;
      $'\001')
        select_all_choices
        ;;
      $'\e')
        IFS= read -rsk1 -t 0.01 next_key || continue
        if [[ "$next_key" == "[" ]]; then
          IFS= read -rsk1 -t 0.01 arrow_key || continue
          case "$arrow_key" in
            A)
              move_cursor_up
              ;;
            B)
              move_cursor_down
              ;;
          esac
        fi
        ;;
    esac
  done
}

choice_labels=("$ACTION_TRACKED" "$ACTION_UNTRACKED")
display_labels=("$ACTION_TRACKED" "$ACTION_UNTRACKED")
choice_values=("__action_tracked__" "__action_untracked__")

for file_path in "${tracked_files[@]}"; do
  status_label=$(status_label_for_path "$file_path")
  choice_labels+=("$status_label")
  display_labels+=("$(colorize_status_label "$status_label")")
  choice_values+=("$file_path")
done

for file_path in "${untracked_files[@]}"; do
  status_label=$(status_label_for_path "$file_path")
  choice_labels+=("$status_label")
  display_labels+=("$(colorize_status_label "$status_label")")
  choice_values+=("$file_path")
done

selected_flags=()
for file_path in "${choice_labels[@]}"; do
  selected_flags+=(0)
done

cursor_index=1
scroll_offset=1
selector_active=false
original_stty_state=""

trap cleanup_selector EXIT INT TERM

if ! run_selector; then
  cleanup_selector
  echo "No files selected. Aborting." >&2
  exit 0
fi

cleanup_selector

selected_paths=()
selected_tracked=false
selected_untracked=false

for ((index = 1; index <= ${#choice_values[@]}; index++)); do
  [[ "${selected_flags[index]}" == "1" ]] || continue

  case "${choice_values[index]}" in
    "__action_tracked__")
      selected_tracked=true
      ;;
    "__action_untracked__")
      selected_untracked=true
      ;;
    *)
      selected_paths+=("${choice_values[index]}")
      ;;
  esac
done

[[ "$selected_tracked" == true ]] && selected_paths+=("${tracked_files[@]}")
[[ "$selected_untracked" == true ]] && selected_paths+=("${untracked_files[@]}")

deduped_paths=()
for candidate in "${selected_paths[@]}"; do
  [[ -z "$candidate" ]] && continue

  already_added=false
  for existing in "${deduped_paths[@]}"; do
    if [[ "$existing" == "$candidate" ]]; then
      already_added=true
      break
    fi
  done

  [[ "$already_added" == false ]] && deduped_paths+=("$candidate")
done

if [[ ${#deduped_paths[@]} -eq 0 ]]; then
  echo "No files selected. Aborting." >&2
  exit 0
fi

git add -- "${deduped_paths[@]}" || exit 1

printf "Staged %d file(s):\n" "${#deduped_paths[@]}"
printf '  %s\n' "${deduped_paths[@]}"
